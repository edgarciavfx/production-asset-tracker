# PostgreSQL connection string (use sslmode=require for production)
DATABASE_URL="postgresql://user:password@localhost:5432/pat?sslmode=require"

# Auth.js secret — must be at least 32 characters
AUTH_SECRET="your-secret-at-least-32-characters-long"

# Public URL of the application (used for Auth.js callbacks)
AUTH_URL="http://localhost:3000"

# Environment (development / production / test)
NODE_ENV="development"
