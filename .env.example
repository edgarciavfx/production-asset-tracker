# Directory where Flipbook stores its SQLite DB and generated media proxies.
# Defaults to ./data relative to the repo root.
FLIPBOOK_DATA_DIR="./data"

# Port the dev/prod server binds to. The Nuke publish button POSTs here.
PORT="3000"

# Path to the system ffmpeg / ffprobe binaries. Defaults to "ffmpeg"/"ffprobe"
# on PATH. Override if they live somewhere non-standard.
FLIPBOOK_FFMPEG="ffmpeg"
FLIPBOOK_FFPROBE="ffprobe"

# Long edge (px) of generated proxy frames. Smaller = faster transcode + lighter
# playback. 1280 is a good default for review.
FLIPBOOK_PROXY_WIDTH="1280"
