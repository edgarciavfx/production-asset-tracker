generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETE
}

enum AssetType {
  CHARACTER
  PROP
  ENVIRONMENT
  VEHICLE
  OTHER
}

enum AssetStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  APPROVED
  COMPLETE
}

enum ShotStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  APPROVED
  COMPLETE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  tasks         Task[]    @relation("TaskAssignee")
  comments      Comment[]
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  assets      Asset[]
  shots       Shot[]
  tasks       Task[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([deletedAt])
  @@index([name])
}

model Asset {
  id        String     @id @default(cuid())
  name      String
  type      AssetType
  status    AssetStatus @default(NOT_STARTED)
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@index([projectId, status])
}

model Shot {
  id          String     @id @default(cuid())
  code        String
  description String?
  status      ShotStatus @default(NOT_STARTED)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@index([projectId, status])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assetId     String?
  asset       Asset?       @relation(fields: [assetId], references: [id])
  shotId      String?
  shot        Shot?        @relation(fields: [shotId], references: [id])
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dueDate     DateTime?
  comments    Comment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([assigneeId])
  @@index([assetId])
  @@index([shotId])
  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([deletedAt])
  @@index([projectId, status])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([taskId])
  @@index([authorId])
  @@index([deletedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
